# Server
PORT=3001

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Care plan trial period in days (subscription billing starts after this many days)
# Set to 0 to charge immediately. Default: 30
CARE_PLAN_TRIAL_DAYS=30

# Company info (used in contracts)
COMPANY_NAME=Tycho Systems
COMPANY_ADDRESS=Remote (US)
GOVERNING_STATE=Texas
GOVERNING_COUNTY=Travis County, Texas
HOURLY_RATE=$150

# Google reCAPTCHA v3  (https://www.google.com/recaptcha/admin)
# 1. Create a site with reCAPTCHA v3 and add your domain
# 2. Set the SECRET key here (keep private — never expose in frontend)
# 3. Set the SITE key in the frontend .env as VITE_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=

# Frontend URL (for CORS + Stripe redirects)
CLIENT_URL=http://localhost:5173
